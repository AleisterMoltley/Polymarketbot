# Polymarket CLOB API credentials
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws
CLOB_API_KEY=your_clob_api_key_here
CLOB_API_SECRET=your_clob_api_secret_here
CLOB_API_PASSPHRASE=your_clob_api_passphrase_here

# Wallet / Polygon
PRIVATE_KEY=your_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# Bot settings
# NOTE: This bot is optimized for 5-minute paper trading only.
# PAPER_TRADE is always enabled regardless of this setting.
PAPER_TRADE=true
MAX_POSITION_SIZE_USDC=100
MIN_EDGE=0.05

# Trading loop interval
# NOTE: This bot always uses 5-minute intervals (300000ms) regardless of this setting.
POLL_INTERVAL_MS=300000

# Admin / API server
PORT=3000
ADMIN_SECRET=change_me_in_production

# WebSocket broadcast interval (ms)
STATS_BROADCAST_INTERVAL_MS=10000

# Data paths
DATA_DIR=./data

# ── 5-Minute Paper Trading Configuration ────────────────────────────────────
# This bot is optimized for 5-minute paper trading only.
# Live trading is disabled in this optimized version.

# Enable speed trading on startup
ENABLE_SPEED_TRADING=false

# Minimum USDC balance required (for simulation purposes)
MIN_BALANCE_USDC=10

# Minimum price lag threshold to trigger trade (0.02 = 2%)
LAG_THRESHOLD=0.02

# Maximum spread to accept (0.05 = 5%)
MAX_SPREAD=0.05

# Throttle: minimum milliseconds between trades per market
THROTTLE_MS=5000

# Number of price samples to track for lag detection
PRICE_HISTORY_SIZE=20

# Time window for last-second trading (ms before 5-min close)
LAST_SECOND_WINDOW_MS=10000

# Market close detection window (ms before anticipated close)
CLOSE_DETECTION_WINDOW_MS=60000

# 5-Minute Market Token IDs
# Configure these with actual Polymarket condition IDs for your target markets
MARKET_5MIN_CONDITION_ID=market-5min
MARKET_5MIN_YES_TOKEN=market-5min-yes
MARKET_5MIN_NO_TOKEN=market-5min-no
