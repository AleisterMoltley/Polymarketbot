# ==============================================================================
# Polymarket Trading Bot - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# All configuration is centralized in src/config/env.ts
# ==============================================================================

# ── Polymarket CLOB API Credentials ─────────────────────────────────────────
# Required for live trading. Optional for paper trading.
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws
CLOB_API_KEY=your_clob_api_key_here
CLOB_API_SECRET=your_clob_api_secret_here
CLOB_API_PASSPHRASE=your_clob_api_passphrase_here

# ── Wallet / Polygon ────────────────────────────────────────────────────────
# Required for live trading. Optional for paper trading.
PRIVATE_KEY=your_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# ── Bot Settings ────────────────────────────────────────────────────────────
# Trading mode: "paper" (simulated) or "live" (real money)
# Can be changed at runtime via the dashboard toggle
TRADING_MODE=paper
MAX_POSITION_SIZE_USDC=100
MIN_EDGE=0.05

# ── Liquidity-Weighted Edge ─────────────────────────────────────────────────
# When enabled, edge is weighted by market liquidity score
# Higher liquidity markets produce higher weighted edges, favoring reliable opportunities
ENABLE_LIQUIDITY_WEIGHTED_EDGE=false

# Reference liquidity for normalization (markets with this liquidity have weight 1.0)
# Lower values make liquidity weighting more aggressive
# Example: $10,000 (default) means a $40,000 liquidity market has score ~2.0
LIQUIDITY_REFERENCE_USDC=10000

# Trading loop interval (default: 300000ms = 5 minutes)
POLL_INTERVAL_MS=300000

# Delay before restarting trading loop after failure (ms)
TRADING_LOOP_RESTART_DELAY_MS=30000

# ── Admin / API Server ──────────────────────────────────────────────────────
PORT=3000
ADMIN_SECRET=change_me_in_production

# WebSocket broadcast interval (ms)
STATS_BROADCAST_INTERVAL_MS=10000

# Data paths
DATA_DIR=./data

# ── Speed Trading Configuration ─────────────────────────────────────────────
# Speed trading exploits last-second price lag opportunities in 5-minute markets

# Enable speed trading on startup
ENABLE_SPEED_TRADING=false

# Minimum USDC balance required to trade
MIN_BALANCE_USDC=10

# Minimum price lag threshold to trigger trade (0.02 = 2%)
LAG_THRESHOLD=0.02

# Maximum spread to accept (0.05 = 5%)
MAX_SPREAD=0.05

# Throttle: minimum milliseconds between trades per market
THROTTLE_MS=5000

# Number of price samples to track for lag detection
PRICE_HISTORY_SIZE=20

# Time window for last-second trading (ms before 5-min close)
LAST_SECOND_WINDOW_MS=10000

# Market close detection window (ms before anticipated close)
CLOSE_DETECTION_WINDOW_MS=60000

# ── 5-Minute Market Token IDs ───────────────────────────────────────────────
# Configure these with actual Polymarket condition IDs for your target markets
MARKET_5MIN_CONDITION_ID=market-5min
MARKET_5MIN_YES_TOKEN=market-5min-yes
MARKET_5MIN_NO_TOKEN=market-5min-no

# ── Market Filters Configuration ────────────────────────────────────────────
# Enable/disable market filtering (default: true)
MARKET_FILTERS_ENABLED=true

# Maximum time until market resolution in milliseconds (default: 300000 = 5 minutes)
# Only markets resolving within this time window will be traded
# Set to 0 to disable this filter
MAX_RESOLUTION_TIME_MS=300000

# Minimum liquidity in USDC (0 = no filter)
# Markets with liquidity below this threshold will be filtered out
MIN_LIQUIDITY=0

# Minimum 24h trading volume in USDC (0 = no filter)
# Markets with volume below this threshold will be filtered out
MIN_VOLUME=0

# Allowed categories (comma-separated, empty = all categories)
# Example: politics,crypto,sports
FILTER_CATEGORIES=

# Excluded categories (comma-separated)
# Example: adult,gambling
EXCLUDE_CATEGORIES=

# Number of markets to fetch per page (max: 1000)
MARKET_PAGE_SIZE=100
