# Polymarket CLOB API credentials
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws
CLOB_API_KEY=your_clob_api_key_here
CLOB_API_SECRET=your_clob_api_secret_here
CLOB_API_PASSPHRASE=your_clob_api_passphrase_here

# Wallet / Polygon
PRIVATE_KEY=your_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# Bot settings
PAPER_TRADE=true
MAX_POSITION_SIZE_USDC=100
MIN_EDGE=0.05
POLL_INTERVAL_MS=30000

# Kalshi API credentials (for cross-platform arbitrage)
KALSHI_API_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_API_KEY=your_kalshi_api_key_here

# Arbitrage settings
ARB_ENABLED=false
ARB_MIN_PRICE_DIFF=0.03
ARB_MAX_BANKROLL_PCT=0.05
ARB_MAX_TRADE_SIZE=50
ARB_POLY_SPREAD=0.01
ARB_COOLDOWN_MS=60000
ARB_POLL_INTERVAL_MS=30000
ARB_AUTO_EXECUTE=false
ARB_DEFAULT_BANKROLL=1000

# Admin / API server
PORT=3000
ADMIN_SECRET=change_me_in_production

# WebSocket broadcast interval (ms)
STATS_BROADCAST_INTERVAL_MS=10000

# Data paths
DATA_DIR=./data
