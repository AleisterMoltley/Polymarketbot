# Polymarket CLOB API credentials
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws
CLOB_API_KEY=your_clob_api_key_here
CLOB_API_SECRET=your_clob_api_secret_here
CLOB_API_PASSPHRASE=your_clob_api_passphrase_here

# Wallet / Polygon
PRIVATE_KEY=your_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# Bot settings
PAPER_TRADE=true
MAX_POSITION_SIZE_USDC=100
MIN_EDGE=0.05
POLL_INTERVAL_MS=30000

# Admin / API server
PORT=3000
ADMIN_SECRET=change_me_in_production

# WebSocket broadcast interval (ms)
STATS_BROADCAST_INTERVAL_MS=10000

# Data paths
DATA_DIR=./data

# ── Speed Trading Configuration ─────────────────────────────────────────────
# Enable 24/7 speed trading on startup (can also be started via API)
ENABLE_SPEED_TRADING=false

# Minimum USDC balance required to trade
MIN_BALANCE_USDC=10

# Minimum price lag threshold to trigger trade (0.02 = 2%)
LAG_THRESHOLD=0.02

# Maximum spread to accept (0.05 = 5%)
MAX_SPREAD=0.05

# Throttle: minimum milliseconds between trades per market
THROTTLE_MS=5000

# Number of price samples to track for lag detection
PRICE_HISTORY_SIZE=20

# Time window for last-second trading (ms before 5-min close)
LAST_SECOND_WINDOW_MS=10000

# Market close detection window (ms before anticipated close)
CLOSE_DETECTION_WINDOW_MS=60000

# Crypto Market Token IDs (5-minute markets)
# These need to be updated with actual Polymarket condition IDs
BTC_5MIN_CONDITION_ID=btc-5min-market
BTC_5MIN_YES_TOKEN=btc-5min-yes
BTC_5MIN_NO_TOKEN=btc-5min-no

ETH_5MIN_CONDITION_ID=eth-5min-market
ETH_5MIN_YES_TOKEN=eth-5min-yes
ETH_5MIN_NO_TOKEN=eth-5min-no

SOL_5MIN_CONDITION_ID=sol-5min-market
SOL_5MIN_YES_TOKEN=sol-5min-yes
SOL_5MIN_NO_TOKEN=sol-5min-no
