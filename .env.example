# Polymarket CLOB API credentials
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws
CLOB_API_KEY=your_clob_api_key_here
CLOB_API_SECRET=your_clob_api_secret_here
CLOB_API_PASSPHRASE=your_clob_api_passphrase_here

# Wallet / Polygon
PRIVATE_KEY=your_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# Bot settings
PAPER_TRADE=true
MAX_POSITION_SIZE_USDC=100
MIN_EDGE=0.05
POLL_INTERVAL_MS=30000

# Admin / API server
PORT=3000
ADMIN_SECRET=change_me_in_production

# WebSocket broadcast interval (ms)
STATS_BROADCAST_INTERVAL_MS=10000

# Data paths
DATA_DIR=./data

# ── Whale Tracking (Copy Trading) ──────────────────────────────────────────
# Enable whale tracking to copy trades from profitable wallets
WHALE_TRACKING_ENABLED=false

# Delay in milliseconds before copying a whale trade (safety buffer)
WHALE_COPY_DELAY_MS=5000

# Maximum price deviation (%) allowed when copying a trade
# If the price has moved more than this, the copy will be skipped
WHALE_MAX_PRICE_DEVIATION=0.02

# Minimum total PnL ($) for a wallet to be considered a whale
WHALE_MIN_PNL=1000

# Minimum win rate (0-1) for a wallet to be tracked
WHALE_MIN_WIN_RATE=0.55

# Maximum Kelly Criterion fraction (0-1) for position sizing
# 0.25 = max 25% of bankroll per trade
WHALE_MAX_KELLY_FRACTION=0.25
