# Polymarket CLOB API credentials
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws
CLOB_API_KEY=your_clob_api_key_here
CLOB_API_SECRET=your_clob_api_secret_here
CLOB_API_PASSPHRASE=your_clob_api_passphrase_here

# Wallet / Polygon
# Option 1: Raw private key (not recommended for production)
PRIVATE_KEY=your_private_key_here

# Option 2: Encrypted private key (recommended)
# Generate with: npx ts-node src/utils/crypto.ts encrypt <your_key> <password>
# PRIVATE_KEY_ENCRYPTED=your_encrypted_key_here
# KEY_PASSWORD=your_encryption_password

POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# Bot settings
PAPER_TRADE=true
MAX_POSITION_SIZE_USDC=100
MIN_EDGE=0.05
POLL_INTERVAL_MS=30000
RISK_LEVEL=medium

# Admin / API server
PORT=3000
ADMIN_SECRET=change_me_in_production

# WebSocket broadcast interval (ms)
STATS_BROADCAST_INTERVAL_MS=10000

# Data paths
DATA_DIR=./data

# ─── Strategy Settings ──────────────────────────────────────────────────────

# Whale Copy Trading
WHALE_COPY_ENABLED=false
WHALE_COPY_MAX_SIZE=50
WHALE_COPY_RATIO=0.1
WHALE_MIN_SIZE=1000
WHALE_COPY_DELAY_MS=2000

# AI Sentiment Analysis
AI_SENTIMENT_ENABLED=false
AI_SENTIMENT_MIN_CONFIDENCE=0.7
AI_SENTIMENT_MAX_SIZE=50
NEWS_API_KEY=your_newsdata_io_api_key_here

# ─── Notifications ──────────────────────────────────────────────────────────

# Telegram Alerts
# 1. Create a bot via @BotFather on Telegram
# 2. Get your chat ID via @userinfobot or @RawDataBot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
