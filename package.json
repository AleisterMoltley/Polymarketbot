{
  "name": "polymarket-trading-bot",
  "version": "1.0.0",
  "description": "Automated trading bot for Polymarket prediction markets",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "backtest": "ts-node src/backtest/backtest.ts",
    "docker:build": "docker build -t polymarket-bot .",
    "docker:run": "docker run -p 3000:3000 --env-file .env polymarket-bot",
    "health-check": "node ok.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "polymarket",
    "prediction-market",
    "trading-bot",
    "polygon"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client": "^5.8.0",
    "axios": "^1.13.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
